<Window x:Class="Tunnelr.Views.EditTunnelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Tunnel"
        Width="320" Height="270"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0a0e1a">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="// EDIT TUNNEL"
                   FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                   Foreground="#ff00aa"/>

        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="Local Port:"
                   FontFamily="Consolas" FontSize="12"
                   Foreground="#c0d0e0"
                   VerticalAlignment="Center"/>
        <TextBox x:Name="txtPort" Grid.Row="2" Grid.Column="1"
                 Style="{StaticResource CyberTextBox}"
                 MaxLength="5"/>

        <TextBlock Grid.Row="4" Grid.Column="0"
                   Text="Remote Port:"
                   FontFamily="Consolas" FontSize="12"
                   Foreground="#c0d0e0"
                   VerticalAlignment="Center"/>
        <TextBox x:Name="txtRemotePort" Grid.Row="4" Grid.Column="1"
                 Style="{StaticResource CyberTextBox}"
                 MaxLength="5"/>

        <TextBlock Grid.Row="6" Grid.Column="0"
                   Text="Name:"
                   FontFamily="Consolas" FontSize="12"
                   Foreground="#c0d0e0"
                   VerticalAlignment="Center"/>
        <TextBox x:Name="txtNickname" Grid.Row="6" Grid.Column="1"
                 Style="{StaticResource CyberTextBox}"
                 MaxLength="30"/>

        <StackPanel Grid.Row="8" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button Content="Save" Style="{StaticResource NeonButton}"
                    Click="Save_Click" Width="80" Margin="0,0,8,0"/>
            <Button Content="Cancel" Style="{StaticResource NeonButton}"
                    Click="Cancel_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
