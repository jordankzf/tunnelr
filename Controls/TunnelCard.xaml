<UserControl x:Class="Tunnelr.Controls.TunnelCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="170" Height="130"
             Cursor="Hand"
             MouseLeftButtonDown="Card_Click">

    <Grid x:Name="cardRoot" Margin="6">
        <!-- Glow border (replaces DropShadowEffect) -->
        <Border x:Name="glowBorder" CornerRadius="6" Margin="-3"
                BorderThickness="3" Opacity="0.25">
            <Border.BorderBrush>
                <SolidColorBrush x:Name="glowColor" Color="#00e5ff"/>
            </Border.BorderBrush>
            <Border.Background>
                <SolidColorBrush Color="Transparent"/>
            </Border.Background>
        </Border>

        <!-- Card body -->
        <Border x:Name="cardBody" CornerRadius="4"
                BorderThickness="1.5"
                BorderBrush="#00667a"
                ClipToBounds="True">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0d1528" Offset="0"/>
                    <GradientStop Color="#111d35" Offset="0.5"/>
                    <GradientStop Color="#0d1528" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <!-- Content -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Nickname -->
                    <TextBlock x:Name="txtNickname"
                               Text="Tunnel"
                               FontFamily="Consolas"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#00e5ff"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"/>

                    <!-- Port number -->
                    <TextBlock x:Name="txtPort"
                               Text="0000"
                               FontFamily="Consolas"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#ff00aa"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <!-- Status orb -->
                    <Grid HorizontalAlignment="Center" Width="16" Height="16">
                        <Ellipse x:Name="orbGlow" Width="16" Height="16">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#4000e5ff" Offset="0"/>
                                    <GradientStop Color="#0000e5ff" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Ellipse x:Name="orbDot" Width="8" Height="8"
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse.Fill>
                                <SolidColorBrush x:Name="orbFill" Color="#553344"/>
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>
                </StackPanel>

                <!-- Corner accents (top-left, bottom-right) -->
                <Path Data="M 0,12 L 0,0 L 12,0" Stroke="#00667a" StrokeThickness="1.5"
                      HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6,6,0,0"/>
                <Path Data="M 0,12 L 12,12 L 12,0" Stroke="#00667a" StrokeThickness="1.5"
                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,6,6"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
